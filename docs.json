{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Synthesize Bio",
  "description": "Documentation for the Synthesize Bio platform, SDKs, and integrations.",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "get-started/introduction",
              "get-started/quickstart"
            ]
          },
          {
            "group": "Python SDK",
            "pages": ["python-sdk/index"]
          },
          {
            "group": "R SDK",
            "pages": ["r-sdk/index"]
          },
          {
            "group": "MCP",
            "pages": ["mcp/index"]
          },
          {
            "group": "Guides",
            "pages": ["guides/index"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Platform",
          "href": "https://app.synthesize.bio",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/synthesizebio",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@synthesize.bio"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Platform",
      "href": "https://app.synthesize.bio"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/synthesizebio",
      "linkedin": "https://www.linkedin.com/company/synthesize-bio",
      "x": "https://x.com/synthesizebio"
    }
  }
}
