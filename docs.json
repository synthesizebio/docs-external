{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Synthesize Bio",
  "description": "Documentation for the Synthesize Bio platform, SDKs, and integrations.",
  "colors": {
    "primary": "#16A34A",
    "light": "#22C55E",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.synthesize.bio"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "get-started/introduction",
              "get-started/quickstart",
              "get-started/available-metadata"
            ]
          },
          {
            "group": "Python SDK",
            "pages": [
              "python-sdk/index",
              "python-sdk/installation",
              "python-sdk/getting-started",
              {
                "group": "Models",
                "pages": [
                  "python-sdk/models/baseline",
                  "python-sdk/models/reference-conditioning",
                  "python-sdk/models/metadata-prediction"
                ]
              },
              "python-sdk/license"
            ]
          },
          {
            "group": "R SDK",
            "pages": [
              "r-sdk/index",
              "r-sdk/installation",
              "r-sdk/getting-started",
              {
                "group": "Models",
                "pages": [
                  "r-sdk/models/baseline",
                  "r-sdk/models/reference-conditioning",
                  "r-sdk/models/metadata-prediction"
                ]
              },
              "r-sdk/reference",
              "r-sdk/license"
            ]
          },
          {
            "group": "MCP",
            "pages": [
              "mcp/index",
              "mcp/overview",
              "mcp/connect-in-claude",
              {
                "group": "Using the connector",
                "pages": [
                  "mcp/how-it-works",
                  "mcp/usage-examples",
                  "mcp/troubleshooting"
                ]
              },
              {
                "group": "Reference",
                "pages": [
                  "mcp/tools-reference",
                  "mcp/authentication",
                  "mcp/privacy-and-support"
                ]
              }
            ]
          },
          {
            "group": "Guides",
            "pages": ["guides/index"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Platform",
          "href": "https://app.synthesize.bio",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/synthesizebio",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@synthesize.bio"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Platform",
      "href": "https://app.synthesize.bio"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/synthesizebio",
      "linkedin": "https://www.linkedin.com/company/synthesize-bio",
      "x": "https://x.com/synthesizebio"
    }
  }
}
