{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Synthesize Bio",
  "description": "Documentation for the Synthesize Bio platform, SDKs, and integrations.",
  "colors": {
    "primary": "#3B6297",
    "light": "#91B0DB",
    "dark": "#2C4A73"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.synthesize.bio"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "get-started/quickstart",
              "get-started/available-metadata"
            ]
          },
          {
            "group": "Resources",
            "pages": ["guides/index"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Python SDK",
          "icon": "python",
          "iconType": "brands",
          "href": "/pysynthbio"
        },
        {
          "anchor": "R SDK",
          "icon": "r-project",
          "iconType": "brands",
          "href": "/rsynthbio"
        },
        {
          "anchor": "MCP",
          "icon": "plug",
          "href": "/platform"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@synthesize.bio"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Platform",
      "href": "https://app.synthesize.bio"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/synthesizebio",
      "linkedin": "https://www.linkedin.com/company/synthesize-bio",
      "x": "https://x.com/synthesizebio"
    },
    "links": [
      {
        "header": "Links",
        "items": [
          {
            "label": "Platform",
            "href": "https://app.synthesize.bio"
          },
          {
            "label": "GitHub",
            "href": "https://github.com/synthesizebio"
          }
        ]
      }
    ]
  }
}
