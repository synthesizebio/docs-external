{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Synthesize Bio",
  "description": "Documentation for the Synthesize Bio platform, SDKs, and integrations.",
  "colors": {
    "primary": "#503E6C",
    "light": "#503E6C",
    "dark": "#D4CCE0"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "seo": {
    "metatags": {
      "canonical": "https://docs.synthesize.bio"
    }
  },
  "navigation": {
    "anchors": [
      {
        "anchor": "Get Started",
        "icon": "book-open",
        "pages": [
          "index",
          "get-started/quickstart",
          "get-started/available-metadata"
        ]
      },
      {
        "anchor": "Python SDK",
        "icon": "python",
        "iconType": "brands",
        "href": "/pysynthbio"
      },
      {
        "anchor": "R SDK",
        "icon": "r-project",
        "iconType": "brands",
        "href": "/rsynthbio"
      },
      {
        "anchor": "MCP",
        "icon": "plug",
        "href": "/platform"
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@synthesize.bio"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Platform",
      "href": "https://app.synthesize.bio"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/synthesizebio",
      "linkedin": "https://www.linkedin.com/company/synthesize-bio",
      "x": "https://x.com/synthesizebio"
    },
    "links": [
      {
        "header": "Links",
        "items": [
          {
            "label": "Platform",
            "href": "https://app.synthesize.bio"
          },
          {
            "label": "GitHub",
            "href": "https://github.com/synthesizebio"
          }
        ]
      }
    ]
  }
